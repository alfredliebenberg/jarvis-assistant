<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0F"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="J.A.R.V.I.S  CONFIGURATION"
            android:textColor="#00E5FF"
            android:textSize="16sp"
            android:letterSpacing="0.15"
            android:layout_marginBottom="24dp" />

        <!-- INTELLIGENCE CORE -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="INTELLIGENCE CORE"
            android:textColor="#607D8B" android:textSize="11sp"
            android:letterSpacing="0.2" android:layout_marginBottom="8dp"/>

        <EditText android:id="@+id/etClaudeKey"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="Claude API Key (sk-ant-...)"
            android:inputType="textPassword"
            android:textColor="#FFFFFF" android:textColorHint="#555555"
            android:background="@drawable/input_bg" android:padding="12dp"
            android:layout_marginBottom="16dp"/>

        <EditText android:id="@+id/etName"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="Your name (Jarvis will use this)"
            android:inputType="textPersonName"
            android:textColor="#FFFFFF" android:textColorHint="#555555"
            android:background="@drawable/input_bg" android:padding="12dp"
            android:layout_marginBottom="24dp"/>

        <!-- WEATHER -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="WEATHER (OpenWeatherMap)"
            android:textColor="#607D8B" android:textSize="11sp"
            android:letterSpacing="0.2" android:layout_marginBottom="4dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Free key at openweathermap.org"
            android:textColor="#607D8B" android:textSize="11sp"
            android:layout_marginBottom="8dp"/>

        <EditText android:id="@+id/etOwmKey"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="OpenWeatherMap API Key"
            android:inputType="textPassword"
            android:textColor="#FFFFFF" android:textColorHint="#555555"
            android:background="@drawable/input_bg" android:padding="12dp"
            android:layout_marginBottom="12dp"/>

        <EditText android:id="@+id/etCity"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="Your city (e.g. Johannesburg)"
            android:inputType="textCapWords"
            android:textColor="#FFFFFF" android:textColorHint="#555555"
            android:background="@drawable/input_bg" android:padding="12dp"
            android:layout_marginBottom="24dp"/>

        <!-- MORNING BRIEFING -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="MORNING BRIEFING"
            android:textColor="#607D8B" android:textSize="11sp"
            android:letterSpacing="0.2" android:layout_marginBottom="8dp"/>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginBottom="12dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Enable morning briefing"
                android:textColor="#B0BEC5" android:textSize="14sp"/>
            <Switch android:id="@+id/swMorningBriefing"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:checked="true"/>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginBottom="24dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Wake-up time:  "
                android:textColor="#B0BEC5" android:textSize="14sp"/>
            <NumberPicker android:id="@+id/npHour"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="  :  " android:textColor="#00E5FF" android:textSize="18sp"/>
            <NumberPicker android:id="@+id/npMinute"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- OUTLOOK CALENDAR -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="OUTLOOK CALENDAR"
            android:textColor="#607D8B" android:textSize="11sp"
            android:letterSpacing="0.2" android:layout_marginBottom="4dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Paste Microsoft Graph token. Get from: developer.microsoft.com/graph/graph-explorer"
            android:textColor="#607D8B" android:textSize="11sp"
            android:layout_marginBottom="8dp"/>

        <EditText android:id="@+id/etMsToken"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="Microsoft Graph Bearer Token (optional)"
            android:inputType="textMultiLine"
            android:minLines="3"
            android:textColor="#FFFFFF" android:textColorHint="#555555"
            android:background="@drawable/input_bg" android:padding="12dp"
            android:layout_marginBottom="24dp"/>

        <!-- SAVE -->
        <Button android:id="@+id/btnSave"
            android:layout_width="match_parent" android:layout_height="48dp"
            android:text="SAVE CONFIGURATION"
            android:textColor="#000000"
            android:backgroundTint="#00E5FF"
            android:layout_marginBottom="24dp"/>

    </LinearLayout>
</ScrollView>
