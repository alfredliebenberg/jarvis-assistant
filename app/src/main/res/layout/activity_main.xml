<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/jarvis_bg">

    <!-- Top header -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="J.A.R.V.I.S"
        android:textColor="@color/jarvis_cyan"
        android:textSize="28sp"
        android:letterSpacing="0.3"
        android:fontFamily="monospace"
        android:paddingTop="48dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Just A Rather Very Intelligent System"
        android:textColor="@color/jarvis_dim"
        android:textSize="11sp"
        android:letterSpacing="0.1"
        android:fontFamily="monospace"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Settings button top right -->
    <ImageButton
        android:id="@+id/btnSettings"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@drawable/ic_settings"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:tint="@color/jarvis_dim"
        android:padding="12dp"
        android:contentDescription="Settings"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="44dp"
        android:layout_marginEnd="16dp"/>

    <!-- Central status ring -->
    <View
        android:id="@+id/statusRing"
        android:layout_width="240dp"
        android:layout_height="240dp"
        android:background="@drawable/ring_inactive"
        app:layout_constraintTop_toBottomOf="@id/tvSubtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tvStatus"
        android:layout_marginTop="48dp"
        android:layout_marginBottom="32dp"/>

    <!-- Power button centered in ring -->
    <ImageButton
        android:id="@+id/btnPower"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@drawable/ic_power_off"
        android:background="@drawable/btn_power_bg"
        android:contentDescription="Power"
        android:padding="20dp"
        app:layout_constraintTop_toTopOf="@id/statusRing"
        app:layout_constraintBottom_toBottomOf="@id/statusRing"
        app:layout_constraintStart_toStartOf="@id/statusRing"
        app:layout_constraintEnd_toEndOf="@id/statusRing"/>

    <!-- Status text -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="OFFLINE"
        android:textColor="@color/jarvis_dim"
        android:textSize="13sp"
        android:letterSpacing="0.2"
        android:fontFamily="monospace"
        app:layout_constraintTop_toBottomOf="@id/statusRing"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tvInstructions"/>

    <!-- Instructions -->
    <TextView
        android:id="@+id/tvInstructions"
        android:layout_width="280dp"
        android:text="Say Hey Jarvis at any time - even with screen off - to activate voice commands."
        android:textColor="@color/jarvis_dim"
        android:textSize="12sp"
        android:textAlignment="center"
        android:lineSpacingExtra="4dp"
        android:fontFamily="monospace"
        android:paddingBottom="32dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
